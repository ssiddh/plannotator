# GitHub OAuth configuration for local Plannotator sessions
#
# Create a GitHub OAuth app at: https://github.com/settings/developers
# - Homepage URL: http://localhost:19432
# - Callback URL: http://localhost:19432/api/auth/github/callback

GITHUB_CLIENT_ID_LOCAL=your-client-id-here
GITHUB_CLIENT_SECRET_LOCAL=your-client-secret-here
